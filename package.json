{
  "name": "competition-monitor",
  "version": "1.0.0",
  "description": "Multi-tenant competition price monitor for MercadoLibre — Search API + Catalog API",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "start": "tsx src/server.ts",
    "scan": "tsx src/cli.ts scan",
    "scan:tenant": "tsx src/cli.ts scan --tenant",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.7.2",
    "cron": "^3.1.7",
    "express": "^4.21.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
